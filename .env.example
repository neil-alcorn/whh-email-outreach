# Copy to .env locally. Never commit the real .env file.

WHH_EMAIL_ADDRESS=name@welcomehomehaiti.com
WHH_EMAIL_DISPLAY_NAME=Welcome Home Haiti

# Cybernautic / Rackspace-style IMAP and SMTP settings
IMAP_HOST=secure.emailsrvr.com
IMAP_PORT=993
IMAP_SECURE=true
SMTP_HOST=secure.emailsrvr.com
SMTP_PORT=465
SMTP_SECURE=true

# Store password or app password only in your local .env.
WHH_EMAIL_PASSWORD=

# Outreach safety controls
DAILY_SEND_LIMIT=15
REQUIRE_APPROVAL_BEFORE_SEND=true
DEFAULT_REPLY_CHECK_DAYS=14
